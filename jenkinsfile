pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                bat 'g++ app.cpp -o app.exe'
            }
        }

        stage('Test') {
            steps {
                bat 'echo Test Passed'
            }
        }

        stage('Docker Build') {
            steps {
                bat 'docker build --no-cache -t mini-devops-cpp-app .'
            }
        }

        stage('Run Container') {
            steps {
                bat '''
                docker stop mini-devops-cpp-app 1>nul 2>&1
                docker rm mini-devops-cpp-app 1>nul 2>&1
                docker run -d --name mini-devops-cpp-app mini-devops-cpp-app
                '''
            }
        }

        stage('Show Output') {
            steps {
                bat 'docker images'
                bat 'docker ps'
            }
        }
    }

    post {
        success {
            echo 'PIPELINE SUCCESSFUL 🎉'
        }
        failure {
            echo 'PIPELINE FAILED ❌'
        }
    }
}